<Window
    x:Class="TreeViewCrud.Views.LoginRegisterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Вход в систему"
    Width="350"
    Height="Auto"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,15"
            HorizontalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Text="Аптечный склад" />

        <TextBlock
            Grid.Row="1"
            Margin="0,5"
            FontWeight="Bold"
            Text="Логин" />
        <TextBox
            x:Name="txtLogin"
            Grid.Row="2"
            Height="30"
            Margin="0,5"
            Padding="5" />

        <TextBlock
            Grid.Row="3"
            Margin="0,5"
            FontWeight="Bold"
            Text="Пароль" />
        <PasswordBox
            x:Name="txtPassword"
            Grid.Row="4"
            Height="30"
            Margin="0,5"
            Padding="5" />

        <TextBlock
            x:Name="txtError"
            Grid.Row="5"
            Margin="0,10,0,0"
            Foreground="Red"
            TextWrapping="Wrap"
            Visibility="Collapsed" />

        <StackPanel
            Grid.Row="6"
            Margin="0,15,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="35"
                Margin="5"
                Background="LightGreen"
                Click="Login_Click"
                Content="Войти" />
            <Button
                Width="100"
                Height="35"
                Margin="5"
                Background="LightGray"
                Click="Cancel_Click"
                Content="Отмена" />
        </StackPanel>
    </Grid>
</Window>