<Window
    x:Class="TreeViewCrud.Views.UserEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Редактирование пользователя"
    Width="400"
    Height="Auto"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  0: метка Логин  -->
            <RowDefinition Height="Auto" />
            <!--  1: поле Логин  -->
            <RowDefinition Height="Auto" />
            <!--  2: метка Фамилия  -->
            <RowDefinition Height="Auto" />
            <!--  3: поле Фамилия  -->
            <RowDefinition Height="Auto" />
            <!--  4: метка Имя  -->
            <RowDefinition Height="Auto" />
            <!--  5: поле Имя  -->
            <RowDefinition Height="Auto" />
            <!--  6: метка Отчество  -->
            <RowDefinition Height="Auto" />
            <!--  7: поле Отчество  -->
            <RowDefinition Height="Auto" />
            <!--  8: метка Роль  -->
            <RowDefinition Height="Auto" />
            <!--  9: поле Роль  -->
            <RowDefinition Height="Auto" />
            <!--  10: метка пароля  -->
            <RowDefinition Height="Auto" />
            <!--  11: поле пароля  -->
            <RowDefinition Height="Auto" />
            <!--  12: чекбокс Активен  -->
            <RowDefinition Height="Auto" />
            <!--  13: кнопки  -->
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,5"
            FontWeight="Bold"
            Text="Логин" />
        <TextBox
            x:Name="txtLogin"
            Grid.Row="1"
            Height="30"
            Margin="0,5" />

        <TextBlock
            Grid.Row="2"
            Margin="0,5"
            FontWeight="Bold"
            Text="Фамилия" />
        <TextBox
            x:Name="txtLastName"
            Grid.Row="3"
            Height="30"
            Margin="0,5" />

        <TextBlock
            Grid.Row="4"
            Margin="0,5"
            FontWeight="Bold"
            Text="Имя" />
        <TextBox
            x:Name="txtFirstName"
            Grid.Row="5"
            Height="30"
            Margin="0,5" />

        <TextBlock
            Grid.Row="6"
            Margin="0,5"
            FontWeight="Bold"
            Text="Отчество" />
        <TextBox
            x:Name="txtPatronymic"
            Grid.Row="7"
            Height="30"
            Margin="0,5" />

        <TextBlock
            Grid.Row="8"
            Margin="0,5"
            FontWeight="Bold"
            Text="Роль" />
        <ComboBox
            x:Name="cmbRole"
            Grid.Row="9"
            Height="30"
            Margin="0,5">
            <ComboBoxItem Content="admin" />
            <ComboBoxItem Content="manager" />
            <ComboBoxItem Content="provizor" />
            <ComboBoxItem Content="pharmacist" />
        </ComboBox>

        <TextBlock
            Grid.Row="10"
            Margin="0,5"
            FontWeight="Bold"
            Text="Пароль (при редактировании оставьте пустым, чтобы не менять)" />
        <PasswordBox
            x:Name="txtPassword"
            Grid.Row="11"
            Height="30"
            Margin="0,5" />

        <CheckBox
            x:Name="chkIsActive"
            Grid.Row="12"
            Margin="0,10"
            Content="Активен" />

        <StackPanel
            Grid.Row="13"
            Margin="0,10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="35"
                Margin="5"
                Background="LightGreen"
                Click="Save_Click"
                Content="Сохранить" />
            <Button
                Width="100"
                Height="35"
                Margin="5"
                Background="LightGray"
                Click="Cancel_Click"
                Content="Отмена" />
        </StackPanel>
    </Grid>
</Window>