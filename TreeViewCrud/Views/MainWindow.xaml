<Window
    x:Class="TreeViewCrud.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TreeViewCrud.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:TreeViewCrud.Models"
    Title="Управление аптечным складом"
    Width="900"
    Height="600"
    FontSize="14"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!--  Шаблон для Batch (3 уровень)  -->
        <HierarchicalDataTemplate DataType="{x:Type models:Batch}">
            <Border
                Margin="2"
                Padding="5"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="3">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="{Binding SerialNumber}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="Срок годности: " />
                        <TextBlock Text="{Binding ExpiryDate, StringFormat=d}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="Цена: " />
                        <TextBlock Text="{Binding SellingPrice, StringFormat=C}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <!--  Шаблон для Item (2 уровень)  -->
        <HierarchicalDataTemplate DataType="{x:Type models:Item}" ItemsSource="{Binding Batches}">
            <Border
                Margin="2"
                Padding="5"
                Background="LightYellow"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="3">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="{Binding Name}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="Дозировка: " />
                        <TextBlock Text="{Binding Dosage}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="Рецепт: " />
                        <TextBlock Text="{Binding PrescriptionRequired, StringFormat=Требуется|Не требуется}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <!--  Шаблон для Category (1 уровень)  -->
        <HierarchicalDataTemplate DataType="{x:Type models:Category}" ItemsSource="{Binding Items}">
            <Border
                Margin="2"
                Padding="8"
                Background="LightBlue"
                BorderBrush="DarkBlue"
                BorderThickness="2"
                CornerRadius="5">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding Name}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="Товаров: " />
                        <TextBlock FontWeight="Bold" Text="{Binding Items.Count}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,20"
            HorizontalAlignment="Center"
            FontSize="24"
            FontWeight="Bold"
            Text="Управление аптечным складом" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!--  TreeView  -->
            <Border
                Grid.Column="0"
                Padding="5"
                BorderBrush="Black"
                BorderThickness="1">
                <TreeView
                    x:Name="MainTreeView"
                    ItemsSource="{Binding Categories}"
                    SelectedItemChanged="TreeView_SelectedItemChanged" />
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="LightGray" />

            <!--  Панель управления  -->
            <Border
                Grid.Column="2"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Управление" />

                    <!--  Информация о выбранном элементе  -->
                    <Border
                        Margin="0,0,0,15"
                        Padding="5"
                        Background="LightGray">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Выбрано:" />
                            <TextBlock
                                Margin="0,5,0,0"
                                Text="{Binding SelectedItemInfo}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Кнопки управления  -->
                    <Button
                        Height="40"
                        Margin="0,5"
                        Background="LightGreen"
                        Command="{Binding AddCategoryCommand}"
                        Content="➕ Добавить категорию"
                        FontSize="14" />

                    <Button
                        Height="40"
                        Margin="0,5"
                        Background="LightGreen"
                        Command="{Binding AddItemCommand}"
                        Content="📦 Добавить товар"
                        FontSize="14" />

                    <Button
                        Height="40"
                        Margin="0,5"
                        Background="LightGreen"
                        Command="{Binding AddBatchCommand}"
                        Content="📦 Добавить партию"
                        FontSize="14" />

                    <Button
                        Height="40"
                        Margin="0,5"
                        Background="LightBlue"
                        Command="{Binding EditCommand}"
                        Content="✏️ Редактировать"
                        FontSize="14" />

                    <Button
                        Height="40"
                        Margin="0,5"
                        Background="LightCoral"
                        Command="{Binding DeleteCommand}"
                        Content="❌ Удалить"
                        FontSize="14" />

                    <Border
                        Margin="0,20,0,0"
                        Padding="5"
                        Background="LightYellow">
                        <TextBlock TextWrapping="Wrap">
                            1. Выберите категорию → добавить товар
                            2. Выберите товар → добавить партию, редактировать, удалить
                            3. Выберите партию → редактировать, удалить
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>