<Window x:Class="TreeViewCrud.Views.ItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F0F0" x:Name="ItemWindowControl">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title, ElementName=ItemWindowControl}"
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Название товара -->
        <StackPanel Grid.Row="1" Margin="0,5">
            <TextBlock Text="Название товара:" FontWeight="Bold"/>
            <TextBox x:Name="txtName" Text="{Binding ItemName, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>

        <!-- МНН -->
        <StackPanel Grid.Row="2" Margin="0,5">
            <TextBlock Text="МНН (международное непатентованное название):" FontWeight="Bold"/>
            <TextBox x:Name="txtMnfName" Text="{Binding ItemMnfName, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>

        <!-- Дозировка -->
        <StackPanel Grid.Row="3" Margin="0,5">
            <TextBlock Text="Дозировка:" FontWeight="Bold"/>
            <TextBox x:Name="txtDosage" Text="{Binding ItemDosage, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>

        <!-- Форма выпуска -->
        <StackPanel Grid.Row="4" Margin="0,5">
            <TextBlock Text="Форма выпуска:" FontWeight="Bold"/>
            <TextBox x:Name="txtForm" Text="{Binding ItemForm, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>

        <!-- Рецептурный -->
        <StackPanel Grid.Row="5" Margin="0,5" Orientation="Horizontal">
            <CheckBox x:Name="chkPrescription" IsChecked="{Binding ItemPrescriptionRequired, ElementName=ItemWindowControl}"
                      VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Требуется рецепт" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Внешние ключи (можно заменить на ComboBox с выбором) -->
        <StackPanel Grid.Row="6" Margin="0,5">
            <TextBlock Text="Категория (ID):" FontWeight="Bold"/>
            <TextBox x:Name="txtCategoryId" Text="{Binding ItemCategoryId, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>
        <StackPanel Grid.Row="7" Margin="0,5">
            <TextBlock Text="Производитель (ID):" FontWeight="Bold"/>
            <TextBox x:Name="txtManufacturerId" Text="{Binding ItemManufacturerId, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>
        <StackPanel Grid.Row="8" Margin="0,5">
            <TextBlock Text="Единица измерения (ID):" FontWeight="Bold"/>
            <TextBox x:Name="txtUnitId" Text="{Binding ItemUnitId, ElementName=ItemWindowControl, UpdateSourceTrigger=PropertyChanged}"
                     Height="30" Margin="0,5,0,0" Padding="5"/>
        </StackPanel>

        <!-- Панель ошибок -->
        <Border Grid.Row="9" Background="#FFE0E0" BorderBrush="Red" BorderThickness="1" CornerRadius="3" Padding="5" Margin="0,10,0,0">
            <TextBlock x:Name="txtError" Foreground="Red" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="10" Click="BtnSave_Click"
                    Background="LightGreen" FontSize="14" IsEnabled="{Binding CanSave, ElementName=ItemWindowControl}"/>
            <Button Content="Отмена" Width="100" Height="35" Margin="10" Click="BtnCancel_Click"
                    Background="LightGray" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>